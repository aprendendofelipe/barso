{
  "name": "barso",
  "version": "0.7.0",
  "description": "Configurações compartilhadas para projetos JS/TS",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./eslint": "./src/shared/eslint.config.cjs",
    "./lint-staged": "./src/shared/lint-staged.cjs",
    "./package.json": "./package.json",
    "./prettier": "./src/shared/prettier.config.cjs",
    "./vitest": "./src/shared/vitest.config.js"
  },
  "bin": {
    "barso": "bin/tn.js",
    "tn": "bin/tn.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "barso": "barso",
    "test": "barso test run --reporter agent",
    "test:run": "barso test run",
    "test:watch": "barso test",
    "lint": "eslint . --max-warnings 0 && prettier --check .",
    "format": "eslint --fix . && prettier --write .",
    "commit": "cz",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.2.10",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.23",
    "commander": "15.0.0",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-github": "6.1.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-primer-react": "9.1.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "barso": "file:",
    "commitizen": "4.3.2",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8"
  },
  "author": "aprendendofelipe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aprendendofelipe/barso.git"
  },
  "keywords": [
    "cli",
    "config",
    "tabnews"
  ]
}
